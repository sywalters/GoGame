{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(mise run *)",
      "Bash(mise install *)",
      "Bash(mise ls *)",
      "Bash(mise exec *)",
      "Bash(mise which *)",
      "Bash(mise use *)",
      "Bash(python -m pytest *)",
      "Bash(python -m black *)",
      "Bash(python -m ruff *)",
      "Bash(pip install *)",
      "Bash(uv run *)"
    ],
    "deny": [
      "Bash(mise implode *)",
      "Bash(mise settings set trusted_config_paths *)"
    ]
  }
}
